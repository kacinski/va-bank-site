generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Example {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
}

model Photo {
  id        Int      @id @default(autoincrement())
  filename  String
  title     String?
  gameDate  DateTime?
  mimeType  String?
  fileData  Bytes?
  folder    String?
  createdAt DateTime @default(now())
}

model Meme {
  id        Int      @id @default(autoincrement())
  filename  String
  title     String?
  mimeType  String?
  fileData  Bytes?
  createdAt DateTime @default(now())
}
